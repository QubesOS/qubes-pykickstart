From d8bdca6af7ac0d4e02c090ee2972ac61bfaac4a4 Mon Sep 17 00:00:00 2001
From: Marek Marczykowski-Górecki <marmarek@invisiblethingslab.com>
Date: Mon, 14 Jul 2025 11:15:53 -0700
Subject: [PATCH] pyproject: make it compatible with older setuptools

Revert d8bdca6af7ac0d4e02c090ee2972ac61bfaac4a4

---
 pyproject.toml | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/pyproject.toml b/pyproject.toml
index 2df659db..b73a7068 100644
--- a/pyproject.toml
+++ b/pyproject.toml
@@ -1,5 +1,5 @@
 [build-system]
-requires = ["setuptools>=77.0.0"]
+requires = ["setuptools>=59.0"]
 build-backend = "setuptools.build_meta"
 
 [project]
@@ -13,7 +13,7 @@ maintainers = [
 ]
 description = 'Python module for manipulating kickstart files'
 readme = "README.rst"
-license-files = ["COPYING"]
+license = { file="COPYING" }
 requires-python = ">=3.6"
 classifiers = [
     "Programming Language :: Python :: 3",
